#!/bin/sh

# shellcheck disable=SC2154,SC3040
trap 'ret=$?; test $ret -ne 0 && printf "\n✘ Failed at step: %s (exit %d)\n" "${CURRENT_STEP:-unknown}" "$ret" >&2; exit $ret' EXIT

set -e
set -o pipefail

CURRENT_STEP="initialization"

if [ "$(uname -m)" = "arm64" ]; then
  HOMEBREW_PREFIX="/opt/homebrew"
else
  HOMEBREW_PREFIX="/usr/local"
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BREWFILE="$SCRIPT_DIR/Brewfile"

if [ ! -f "$BREWFILE" ]; then
  printf "Error: Brewfile not found at %s\n" "$BREWFILE" >&2
  exit 1
fi

CURRENT_STEP="setting up Homebrew prefix"
if [ -d "$HOMEBREW_PREFIX" ]; then
  if ! [ -r "$HOMEBREW_PREFIX" ]; then
    sudo chown -R "$LOGNAME:admin" "$HOMEBREW_PREFIX"
  fi
else
  sudo mkdir "$HOMEBREW_PREFIX"
  sudo chflags norestricted "$HOMEBREW_PREFIX"
  sudo chown -R "$LOGNAME:admin" "$HOMEBREW_PREFIX"
fi

if ! command -v brew >/dev/null; then
  printf "\n==> Installing Homebrew...\n"
  /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  export PATH="$HOMEBREW_PREFIX/bin:$PATH"
fi

CURRENT_STEP="removing conflicting packages"
printf "\n==> Removing conflicting packages...\n"
for remove in azure-cli aws-sam-cli; do
  if brew list --formula "$remove" >/dev/null 2>&1; then
    printf "  Removing %s...\n" "$remove"
    brew uninstall "$remove"
  fi
done

CURRENT_STEP="fixing package overwrites"
printf "\n==> Fixing package link conflicts...\n"
for overwrite in python@3.13 awscli bash-completion git go; do
  brew install --overwrite "$overwrite"
done

CURRENT_STEP="updating Homebrew formulae"
printf "\n==> Updating Homebrew formulae...\n"
brew update --force # https://github.com/Homebrew/brew/issues/1151

CURRENT_STEP="installing packages from Brewfile"
printf "\n==> Installing packages from Brewfile...\n"
brew bundle -f --file="$BREWFILE"

CURRENT_STEP="checking Mac App Store login"
printf "\n==> Checking Mac App Store...\n"
if mas account >/dev/null 2>&1; then
  printf "  Signed in to App Store\n"
  mas install 937984704 || printf "  Warning: Failed to install Amphetamine (may already be installed)\n"
else
  printf "  Not signed in to App Store — skipping App Store installs\n"
fi

CURRENT_STEP="cleaning up"
printf "\n==> Cleaning up old Homebrew versions...\n"
brew cleanup

CURRENT_STEP="running customizations"
if [ -f "$HOME/.laptop.local" ]; then
  printf "\n==> Running your customizations from ~/.laptop.local...\n"
  # shellcheck disable=SC1090 disable=SC1091
  . "$HOME/.laptop.local"
fi

CURRENT_STEP="configuring zsh theme"
if ! grep -qF "powerlevel10k.zsh-theme" "$HOME/.zshrc" 2>/dev/null; then
  printf "\n==> Adding powerlevel10k to ~/.zshrc...\n"
  printf "source %s/opt/powerlevel10k/powerlevel10k.zsh-theme\n" "$(brew --prefix)" >>"$HOME/.zshrc"
fi

printf "\n✓ Setup complete!\n"
